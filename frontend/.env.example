# Frontend Environment Variables
# Copy this file to .env.local for local development

# API Configuration
# Replace with your actual backend API URL in production
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Authentication Secret
# Generate a strong random secret (min 32 characters)
# You can use: openssl rand -base64 32
NEXT_PUBLIC_BETTER_AUTH_SECRET=your-secret-key-here-min-32-characters-long

# Optional: Better Auth Configuration
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
